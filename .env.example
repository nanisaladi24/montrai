# ── Broker Selection ───────────────────────────────────────────────────────────
# "alpaca" = paper trading via Alpaca (recommended default)
# "robinhood" = live trading via Robinhood
BROKER=alpaca
TRADING_MODE=paper

# ── Alpaca ─────────────────────────────────────────────────────────────────────
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_PAPER=true          # set false for live Alpaca account

# ── Robinhood (live only) ──────────────────────────────────────────────────────
ROBINHOOD_USERNAME=your_email@example.com
ROBINHOOD_PASSWORD=your_password
ROBINHOOD_MFA_CODE=optional_totp_secret

# ── Financial Datasets (financialdatasets.ai) ──────────────────────────────────
# Primary source for equity/ETF OHLCV + fundamentals. Replaces yfinance for
# SEC-tickered securities.
# Get key at: https://financialdatasets.ai
FINANCIAL_DATASETS_API_KEY=your_financial_datasets_api_key

# ── Polygon / massive.com ──────────────────────────────────────────────────────
# REST: VIX/VVIX/VIX3M indices, intraday minute bars, options chain history.
POLYGON_API_KEY=your_polygon_api_key
# S3 flat files (optional — bulk historical backtesting). Requires a tier with
# flat-file download permission. Leave blank to skip.
POLYGON_S3_ACCESS_KEY=
POLYGON_S3_SECRET_KEY=
POLYGON_S3_ENDPOINT=https://files.massive.com
POLYGON_S3_BUCKET=flatfiles

# ── Trade-mode switches ────────────────────────────────────────────────────────
# Override dashboard defaults at boot. Runtime values in config/runtime.json
# are hot-reloadable; env only sets defaults when runtime.json is absent.
STOCK_TRADING_ENABLED=false
OPTIONS_TRADING_ENABLED=true
INTRADAY_ENABLED=false
COVERED_CALL_ENABLED=false

# ── Optional: Email alerts ─────────────────────────────────────────────────────
ALERT_EMAIL=your_email@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
